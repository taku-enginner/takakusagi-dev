---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const works = await getCollection('works');
  return works.map((work) => ({
    params: { slug: work.id },
    props: { work },
  }));
}

const { work } = Astro.props;
const { Content } = await render(work);
---

<Base title={work.data.title} description={work.data.summary}>
  <article class="py-16 md:py-24">
    <div class="mx-auto max-w-[var(--container-3xl)] px-6 md:px-8">
      <a
        href="/#works"
        class="inline-flex items-center gap-1.5 text-sm text-[color:var(--color-fg-soft)] hover:text-[color:var(--color-accent-dark)] transition-colors mb-8"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="w-4 h-4"
          aria-hidden="true"
        >
          <path d="m12 19-7-7 7-7"></path>
          <path d="M19 12H5"></path>
        </svg>
        作品一覧に戻る
      </a>

      <header class="mb-10">
        <p class="text-xs font-medium tracking-widest text-[color:var(--color-accent-dark)] uppercase mb-3">
          Works
        </p>
        <h1
          class="text-3xl md:text-5xl font-bold tracking-tight text-[color:var(--color-fg)] mb-4"
        >
          {work.data.title}
        </h1>
        <p class="text-base md:text-lg text-[color:var(--color-fg-soft)] leading-relaxed">
          {work.data.summary}
        </p>

        {
          work.data.techStack && work.data.techStack.length > 0 && (
            <div class="mt-6">
              <p class="text-xs text-[color:var(--color-muted)] uppercase tracking-wider mb-2">
                Tech Stack
              </p>
              <ul class="flex flex-wrap gap-2">
                {work.data.techStack.map((tech) => (
                  <li class="px-2.5 py-1 rounded-full text-xs bg-[color:var(--color-accent-soft)] text-[color:var(--color-accent-dark)]">
                    {tech}
                  </li>
                ))}
              </ul>
            </div>
          )
        }

        {
          (work.data.liveUrl || work.data.sourceUrl) && (
            <div class="mt-6 flex flex-wrap gap-3">
              {work.data.liveUrl && (
                <a
                  href={work.data.liveUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-1.5 px-4 py-2 rounded-full bg-[color:var(--color-accent-dark)] text-[color:var(--color-surface)] text-sm font-medium hover:bg-[color:var(--color-accent)] transition-colors"
                >
                  実物を見る
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="w-3.5 h-3.5"
                    aria-hidden="true"
                  >
                    <path d="M7 7h10v10"></path>
                    <path d="M7 17 17 7"></path>
                  </svg>
                </a>
              )}
              {work.data.sourceUrl && (
                <a
                  href={work.data.sourceUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-1.5 px-4 py-2 rounded-full border border-[color:var(--color-border)] text-[color:var(--color-fg-soft)] text-sm font-medium hover:border-[color:var(--color-accent)] hover:text-[color:var(--color-accent-dark)] transition-colors"
                >
                  ソースコード
                </a>
              )}
            </div>
          )
        }
      </header>

      {
        work.data.thumbnail && (
          <figure class="mb-12 rounded-2xl bg-gradient-to-br from-[color:var(--color-accent-soft)]/60 to-[color:var(--color-accent-soft)]/20 border border-[color:var(--color-border)] p-8 md:p-12 flex items-center justify-center">
            <img
              src={work.data.thumbnail}
              alt={`${work.data.title} のスクリーンショット`}
              class="max-h-[520px] w-auto object-contain drop-shadow-lg rounded-lg"
              loading="lazy"
            />
          </figure>
        )
      }

      <div class="prose-custom prose-takakusagi">
        <Content />
      </div>
    </div>
  </article>
</Base>

<style is:global>
  .prose-takakusagi {
    color: var(--color-fg-soft);
    line-height: 1.9;
    max-width: none;
  }
  .prose-takakusagi h2 {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-fg);
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    letter-spacing: -0.01em;
  }
  .prose-takakusagi h3 {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-fg);
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }
  .prose-takakusagi p {
    margin-top: 1rem;
    margin-bottom: 1rem;
  }
  .prose-takakusagi ul {
    list-style: disc;
    padding-left: 1.5rem;
    margin-top: 1rem;
    margin-bottom: 1rem;
  }
  .prose-takakusagi ul li {
    margin-top: 0.25rem;
    margin-bottom: 0.25rem;
  }
  .prose-takakusagi strong {
    color: var(--color-fg);
    font-weight: 700;
  }
  .prose-takakusagi a {
    color: var(--color-accent-dark);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: color-mix(in srgb, var(--color-accent) 40%, transparent);
  }
  .prose-takakusagi a:hover {
    text-decoration-color: var(--color-accent);
  }
  .prose-takakusagi code {
    font-family: ui-monospace, "SFMono-Regular", Menlo, monospace;
    font-size: 0.9em;
    padding: 0.125rem 0.375rem;
    background-color: var(--color-accent-soft);
    color: var(--color-accent-dark);
    border-radius: 0.25rem;
  }
  .prose-takakusagi pre {
    background-color: #2a2a2a;
    color: #f5f5f5;
    padding: 1rem 1.25rem;
    border-radius: 0.5rem;
    overflow-x: auto;
    margin-top: 1.25rem;
    margin-bottom: 1.25rem;
    font-size: 0.875rem;
    line-height: 1.6;
  }
  .prose-takakusagi pre code {
    background: transparent;
    color: inherit;
    padding: 0;
  }
</style>
