---
interface Props {
  id?: string;
  eyebrow?: string;
  title: string;
  class?: string;
}
const { id, eyebrow, title, class: className = '' } = Astro.props;
---

<section id={id} class={`scroll-mt-16 sm:scroll-mt-20 py-12 sm:py-16 md:py-24 ${className}`}>
  <div class="mx-auto max-w-[var(--container-3xl)] px-6 md:px-8">
    {
      eyebrow && (
        <p class="text-xs font-medium tracking-widest text-[color:var(--color-accent-dark)] uppercase mb-3">
          {eyebrow}
        </p>
      )
    }
    <h2
      class="text-xl sm:text-2xl md:text-3xl font-bold tracking-tight text-[color:var(--color-fg)] mb-6 sm:mb-8"
    >
      {title}
    </h2>
    <slot />
  </div>
</section>
