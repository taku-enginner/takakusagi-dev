---
interface Props {
  href: string;
  title: string;
  summary: string;
  tags: readonly string[];
  thumbnail?: string;
}

const { href, title, summary, tags, thumbnail } = Astro.props;
---

<a
  href={href}
  class="group block rounded-2xl border border-[color:var(--color-border)] bg-[color:var(--color-surface)] overflow-hidden hover:border-[color:var(--color-accent)] hover:shadow-md transition-all"
>
  <div class="aspect-[16/9] bg-gradient-to-br from-[color:var(--color-accent-soft)]/60 to-[color:var(--color-accent-soft)]/20 overflow-hidden flex items-center justify-center p-4">
    {
      thumbnail ? (
        <img
          src={thumbnail}
          alt=""
          class="max-w-full max-h-full object-contain group-hover:scale-[1.03] transition-transform duration-500 drop-shadow-md"
          loading="lazy"
        />
      ) : (
        <div class="w-full h-full flex items-center justify-center text-[color:var(--color-accent)]">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="w-12 h-12 opacity-60"
            aria-hidden="true"
          >
            <rect x="3" y="3" width="18" height="18" rx="2"></rect>
            <circle cx="9" cy="9" r="2"></circle>
            <path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"></path>
          </svg>
        </div>
      )
    }
  </div>
  <div class="p-5 sm:p-6">
    <h3
      class="text-base sm:text-lg font-semibold tracking-tight text-[color:var(--color-fg)] group-hover:text-[color:var(--color-accent-dark)] transition-colors"
    >
      {title}
    </h3>
    <p class="mt-2 text-xs sm:text-sm text-[color:var(--color-fg-soft)] leading-relaxed">
      {summary}
    </p>
    {
      tags && tags.length > 0 && (
        <ul class="mt-4 flex flex-wrap gap-2">
          {tags.map((tag) => (
            <li class="px-2.5 py-1 rounded-full text-xs bg-[color:var(--color-accent-soft)] text-[color:var(--color-accent-dark)]">
              {tag}
            </li>
          ))}
        </ul>
      )
    }
  </div>
</a>
