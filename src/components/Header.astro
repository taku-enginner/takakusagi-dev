---
const navItems = [
  { label: 'About', href: '/#about' },
  { label: 'Works', href: '/#works' },
  { label: 'Contact', href: '/#contact' },
];
---

<header
  class="sticky top-0 z-40 backdrop-blur-md bg-[color:var(--color-bg)]/80 border-b border-[color:var(--color-border)]"
>
  <div
    class="mx-auto max-w-[var(--container-3xl)] px-4 sm:px-6 md:px-8 h-14 sm:h-16 flex items-center justify-between gap-3"
  >
    <a
      href="/"
      class="flex items-center gap-2 sm:gap-2.5 font-semibold tracking-tight text-sm sm:text-base md:text-lg text-[color:var(--color-fg)] hover:text-[color:var(--color-accent-dark)] transition-colors shrink-0 min-w-0"
      aria-label="takakusagi.dev トップへ"
    >
      <img
        src="/images/works/irasuto1_icon.webp"
        alt=""
        width="32"
        height="32"
        class="w-7 h-7 sm:w-8 sm:h-8 rounded-full ring-1 ring-[color:var(--color-border)] shrink-0"
      />
      <span class="truncate">
        takakusagi<span class="text-[color:var(--color-accent)]">.</span>dev
      </span>
    </a>
    <nav aria-label="メインナビゲーション" class="shrink-0">
      <ul class="flex items-center gap-3 sm:gap-5 md:gap-8 text-xs sm:text-sm">
        {
          navItems.map(({ label, href }) => (
            <li>
              <a
                href={href}
                class="text-[color:var(--color-fg-soft)] hover:text-[color:var(--color-accent-dark)] transition-colors"
              >
                {label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>
